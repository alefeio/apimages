# Apenas apimg.com.br — não altera outros server_name (Methodus, etc.).
# Certificado esperado: /etc/letsencrypt/live/apimg.com.br/
# (ex.: certbot emitiu o cert mas falhou em "Deploying certificate").
#
# sudo cp deploy/nginx-apimg.https.conf.example /etc/nginx/sites-available/apimg.com.br
# sudo ln -sf /etc/nginx/sites-available/apimg.com.br /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
#
# Se nginx -t reclamar de ssl_dhparam, comente a linha ssl_dhparam ou gere:
#   sudo certbot certonly --nginx -d apimg.com.br  # já feito
#   (às vezes o ficheiro está em /etc/letsencrypt/ssl-dhparams.pem após certbot)

upstream apimages_backend {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name apimg.com.br www.apimg.com.br;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name apimg.com.br www.apimg.com.br;

    ssl_certificate /etc/letsencrypt/live/apimg.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/apimg.com.br/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 20m;
    client_body_timeout 120s;

    location / {
        proxy_pass http://apimages_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
