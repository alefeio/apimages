# URL pública da API (sem barra final) — usada no JSON de resposta do upload
# Ex.: https://img.seudominio.com ou https://123.45.67.89
BASE_URL=http://localhost:8000

# Chave para permitir upload (envie no header: X-API-Key ou Authorization: Bearer ...)
API_KEY=gere-uma-chave-longa-e-secreta

# Pasta onde as imagens ficam salvas (criada automaticamente se não existir)
STORAGE_PATH=./data/uploads

# Tamanho máximo do arquivo em bytes (padrão 10 MB)
MAX_UPLOAD_BYTES=10485760

# Maior lado da imagem em pixels após otimização (0 = nunca redimensionar). Ex.: 1920, 2560
IMAGE_MAX_EDGE_PX=2560
IMAGE_JPEG_QUALITY=90
IMAGE_WEBP_QUALITY=92
